{
    "name": "parking-lot-system",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "workspaces": [
        "client"
    ],
    "scripts": {
        "dev": "concurrently -k \"npm:server\" \"npm:client\"",
        "server": "node server/index.js",
        "client": "npm run dev --workspace client",
        "build": "npm run build --workspace client",
        "start": "node server/index.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "sql.js": "^1.12.0"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}